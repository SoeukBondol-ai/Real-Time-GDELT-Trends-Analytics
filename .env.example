# Project name
COMPOSE_PROJECT_NAME=realtime_twitter_trends

# Airflow
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin
AIRFLOW_FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=

# PostgreSQL and TimescaleDB
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow
TRENDS_DB_USER=trends
TRENDS_DB_PASSWORD=trends
TRENDS_DB_NAME=trends_db

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Producer
# Options: mock, bluesky, gdelt, all
PRODUCER_MODE=mock
MOCK_INTERVAL_SECONDS=1.5
GDELT_QUERY=technology OR ai OR crypto OR climate OR election
GDELT_POLL_SECONDS=60
BLUESKY_JETSTREAM_URL=wss://jetstream1.us-east.bsky.network/subscribe?wantedCollections=app.bsky.feed.post

# Backend
BACKEND_PORT=8000
DATABASE_URL=postgresql://trends:trends@postgres:5432/trends_db
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio12345
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=trends-raw

# Frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/trends
